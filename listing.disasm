1FFE4  0E14     MOVLW 0x14                        120:       MOVLW 20			;MOVE LITERAL TO W
1FFE6  6E01     MOVWF 0x1, ACCESS                 121:       MOVWF outerCount, C		;STORE IT IN OUTERCOUNT (DELAY MULT)
1FFE8  0EB4     MOVLW 0xB4                        122:       MOVLW 180
1FFEA  6E00     MOVWF 0x0, ACCESS                 123:       MOVWF innerCount, C
