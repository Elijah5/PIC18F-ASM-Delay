                                                  125:   delayOuter:
                                                  126:   delayInner:
1FFEC  2E00     DECFSZ 0x0, F, ACCESS             127:       DECFSZ  innerCount, F, A	;1 CYCLE IF NOT 0, 3 CYCLES IF SKIP | DECREMENT F, SKIP IF ZERO
1FFEE  EFF6     GOTO 0x1FFEC                      128:       GOTO    delayInner		;2 CYCLES | RESET PC @ DELAY INNER
1FFF2  2E01     DECFSZ 0x1, F, ACCESS             129:       DECFSZ  outerCount, F, A
