1FFB4  6B10     CLRF 0x10, BANKED                 93:        CLRF ANSELC, B		;CLEAR TO SET DIGITAL
                                                  94:        
                                                  95:    				;SETUP WEAK PULLUP RESISTORS
1FFB6  0104     MOVLB 0x4                         96:        BANKSEL WPUB		;SELECT BANK
1FFB8  8909     BSF 0x9, 4, BANKED                97:        BSF	WPUB4			;TURN ON WEAK PULLUPS
1FFBA  80D0     BSF 0xFD0, 0, ACCESS              98:        BSF RC0			;SET PORTC BIT 0 TO HAVE AN LED / BIT TO ROTATE
                                                  99:        
                                                  100:   mainLoop:
1FFBC  ECE4     CALL 0x1FFC8, 0                   101:       CALL runLeft		;ROTATE ACTIVE LED TO THE LEFT
1FFC0  ECEB     CALL 0x1FFD6, 0                   102:       CALL runRight		;ROTATE ACTIVE LED TO THE RIGHT
1FFC4  EFDE     GOTO 0x1FFBC                      103:       GOTO mainLoop		;KEEP RUNNING MAIN LOOP
                                                  104:       
                                                  105:   runLeft:
1FFC8  46D0     RLNCF 0xFD0, F, ACCESS            106:       RLNCF PORTC, A		;ROTATE PORTC (ACTIVE LED) LEFT WITH NO CARRY
1FFCA  ECF2     CALL 0x1FFE4, 0                   107:       CALL delay			;ADD A DELAY INBETWEEN
1FFCE  BED0     BTFSC 0xFD0, 7, ACCESS            108:       BTFSC RC7			;CHECK IF BIT / LED IN POSITION 7 IS CLEAR
1FFD0  0012     RETURN 0                          109:       RETURN			;IF THE BIT IS SET, BREAK THIS LOOP AND GOTO MAIN LOOP (RIGHT DIRECTION LOOP RUNS NEXT)
1FFD2  EFE4     GOTO 0x1FFC8                      110:       GOTO runLeft		;STAY IN THIS LOOP OTHERWISE
                                                  111:       
                                                  112:   runRight:
1FFD6  42D0     RRNCF 0xFD0, F, ACCESS            113:       RRNCF PORTC, A		;ROTATE PORTC (ACTIVE LED) RIGHT WITH NO CARRY
1FFD8  ECF2     CALL 0x1FFE4, 0                   114:       CALL delay			;ADD A DELAY INBETWEEN
1FFDC  B0D0     BTFSC 0xFD0, 0, ACCESS            115:       BTFSC RC0			;CHECK IF BIT / LED IN POSITION 0 IS CLEAR
1FFDE  0012     RETURN 0                          116:       RETURN			;IF THE BIT IS SET, BREAK THIS LOOP AND GOTO MAIN LOOP (LEFT DIRECTION LOOP RUNS NEXT)
1FFE0  EFEB     GOTO 0x1FFD6                      117:       GOTO runRight		;STAY IN THIS LOOP OTHERWISE
