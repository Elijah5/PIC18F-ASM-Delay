1FFF8  0000     NOP                               131:       NOP				;1 CLOCK CYCLE
1FFFA  0000     NOP                               132:       NOP				;1 CLOCK CYCLE
1FFFC  0012     RETURN 0                          133:       RETURN			;RETURN TO MAIN LOOP / PC
