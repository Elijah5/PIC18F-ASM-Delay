                                                  85:    				;SETUP
1FFAA  88C7     BSF 0xFC7, 4, ACCESS              86:        BSF TRISB4			;MAKE RB4 AN INPUT	
1FFAC  6AD0     CLRF 0xFD0, ACCESS                87:        CLRF PORTC, A		;CLEAR PORT C BEFORE MAKING INPUT	
